local frozen = {} -- [Player] = true/false

local function setFrozen(plr, state)
    local char = plr.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    frozen[plr] = state

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Anchored = state
        end
    end

    if state then
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
    else
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
    end
end

local function getTargetsFromArg(arg)
    arg = string.lower(arg)
    local targets = {}

    if arg == "all" then
        for _, plr in ipairs(Players:GetPlayers()) do
            if ROLES[plr.Name] then
                table.insert(targets, plr)
            end
        end
    else
        for _, plr in ipairs(Players:GetPlayers()) do
            if string.sub(string.lower(plr.Name), 1, #arg) == arg then
                table.insert(targets, plr)
            end
        end
    end

    return targets
end

local function fakeSay(targetPlr, message)
    local char = targetPlr.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    Chat:Chat(head, message, Enum.ChatColor.White)

    pcall(function()
        StarterGui:SetCore("ChatMakeSystemMessage", {
            Text = targetPlr.Name .. ": " .. message;
            Color = Color3.new(1, 1, 1);
        })
    end)
end

