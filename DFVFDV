local function getPlayerFromArg(arg)
    arg = string.lower(arg)
    for _, plr in ipairs(Players:GetPlayers()) do
        if string.sub(string.lower(plr.Name), 1, #arg) == arg then
            return plr
        end
    end
end

local function spinPlayer(plr)
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    task.spawn(function()
        local start = tick()
        while tick() - start < 6 and task.wait() do
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(25), 0)
        end
    end)
end

local function orbitPlayerAroundYou(plr)
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local myChar = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    task.spawn(function()
        local start = tick()
        local radius = 5
        while tick() - start < 8 and task.wait() do
            local t = tick() * 2
            local offset = Vector3.new(math.cos(t) * radius, 0, math.sin(t) * radius)
            hrp.CFrame = CFrame.new(myHRP.Position + offset, myHRP.Position)
        end
    end)
end

local function tpMeTo(plr)
    local myChar = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    local char = plr.Character
    if not myHRP or not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    TweenService:Create(
        myHRP,
        TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { CFrame = hrp.CFrame * CFrame.new(0, 0, -3) }
    ):Play()
end

local function tpHere(plr)
    local myChar = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    local char = plr.Character
    if not myHRP or not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    TweenService:Create(
        hrp,
        TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { CFrame = myHRP.CFrame * CFrame.new(0, 0, -3) }
    ):Play()
end

local function sparklePlayer(plr)
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local p = Instance.new("ParticleEmitter")
    p.Name = "AR_Sparkles"
    p.Texture = "rbxassetid://241594408"
    p.Color = ColorSequence.new(Color3.fromRGB(255,0,255), Color3.fromRGB(0,255,255))
    p.Rate = 40
    p.Lifetime = NumberRange.new(0.4, 0.6)
    p.Speed = NumberRange.new(1, 3)
    p.Parent = hrp

    task.delay(8, function()
        if p then p:Destroy() end
    end)
end

local function spamFakeSay(plr, message)
    for i = 1, 10 do
        fakeSay(plr, message)
        task.wait(0.15)
    end
end

