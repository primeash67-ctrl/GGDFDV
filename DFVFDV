local function animateBar(duration)
    local steps = 100
    local stepTime = duration / steps
    for i = 1, steps do
        local pct = i / steps
        TweenService:Create(
            barFill,
            TweenInfo.new(stepTime, Enum.EasingStyle.Linear),
            { Size = UDim2.new(pct, 0, 1, 0) }
        ):Play()
        percentLabel.Text = math.floor(pct * 100) .. "%"
        task.wait(stepTime)
    end
end

