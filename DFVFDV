-- GOKU TP
---------------------------------------------------------------------

local function gokuTeleportTo(targetPlr)
    if not targetPlr or targetPlr == localPlayer then return end

    local localChar = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local targetChar = targetPlr.Character
    if not targetChar then return end

    local hrp = localChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not hrp or not targetHRP then return end

    local targetCFrame = targetHRP.CFrame * CFrame.new(0, 0, -3)
    TweenService:Create(
        hrp,
        TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { CFrame = targetCFrame }
    ):Play()
end

---------------------------------------------------------------------
-- DISTANCE-BASED TEXT VISIBILITY
---------------------------------------------------------------------

local function hookDistanceVisibility(billboard, label)
    local head = billboard.Adornee
    if not head then return end

    RunService.RenderStepped:Connect(function()
        if not head.Parent or not billboard.Parent then
            return
        end
        local cam = workspace.CurrentCamera
        if not cam then return end

        local dist = (cam.CFrame.Position - head.Position).Magnitude
        if dist > FAR_HIDE_DISTANCE then
            label.TextTransparency = 1
            label.TextStrokeTransparency = 1
        else
            label.TextTransparency = 0
            label.TextStrokeTransparency = 0.35
        end
    end)
end

