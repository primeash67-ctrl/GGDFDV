cmdBox.Size = UDim2.new(1, -12, 1, -8)
cmdBox.Position = UDim2.new(0, 6, 0, 4)
cmdBox.BackgroundTransparency = 1
cmdBox.Text = ""
cmdBox.PlaceholderText = ";freeze, ;say, ;spin, ;orbit, ;tpme, ;tphere, ;sparkle, ;spam"
cmdBox.TextColor3 = Color3.fromRGB(255, 255, 255)
cmdBox.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
cmdBox.Font = Enum.Font.Gotham
cmdBox.TextSize = 16
cmdBox.ClearTextOnFocus = false
cmdBox.Parent = commandFrame

if commandFrame.Visible then
    cmdBox:CaptureFocus()
end

cmdBox.FocusLost:Connect(function(enterPressed)
    if not enterPressed then return end
    if ROLES[localPlayer.Name] ~= "Owner" then return end

    local text = string.lower(cmdBox.Text)
    cmdBox.Text = ""

    if string.sub(text, 1, 1) == ";" then
        text = string.sub(text, 2)
    end

    local parts = {}
    for token in string.gmatch(text, "%S+") do
        table.insert(parts, token)
    end
    local cmd = parts[1]
    local arg = parts[2] or ""

    if not cmd then return end

    if cmd == "freeze" and arg ~= "" then
        for _, plr in ipairs(getTargetsFromArg(arg)) do
            setFrozen(plr, true)
        end

    elseif cmd == "unfreeze" and arg ~= "" then
        for _, plr in ipairs(getTargetsFromArg(arg)) do
            setFrozen(plr, false)
        end

    elseif cmd == "say" and arg ~= "" then
        local targetName = arg
        local msg = table.concat(parts, " ", 3)
        if msg ~= "" then
            local targets = getTargetsFromArg(targetName)
            for _, plr in ipairs(targets) do
                fakeSay(plr, msg)
            end
        end

    elseif cmd == "spin" and arg ~= "" then
        local plr = getPlayerFromArg(arg)
        if plr then spinPlayer(plr) end

    elseif cmd == "orbit" and arg ~= "" then
        local plr = getPlayerFromArg(arg)
        if plr then orbitPlayerAroundYou(plr) end

    elseif cmd == "tpme" and arg ~= "" then
        local plr = getPlayerFromArg(arg)
        if plr then tpMeTo(plr) end

    elseif cmd == "tphere" and arg ~= "" then
        local plr = getPlayerFromArg(arg)
        if plr then tpHere(plr) end

    elseif cmd == "sparkle" and arg ~= "" then
        local plr = getPlayerFromArg(arg)
        if plr then sparklePlayer(plr) end

    elseif cmd == "spam" and arg ~= "" then
        local targetName = arg
        local msg = table.concat(parts, " ", 3)
        if msg ~= "" then
            local plr = getPlayerFromArg(targetName)
            if plr then spamFakeSay(plr, msg) end
        end
    end

    -- re-focus so you can type next command quickly
    cmdBox:CaptureFocus()
end)

